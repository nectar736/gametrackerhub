<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Board Game Tracker</title>
  <meta name="description" content="Track your board game plays, players, and statistics">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="#" class="logo" onclick="app.navigate('dashboard');return false;">
        <span class="logo-icon">🎲</span>
        <span>Board Game Tracker</span>
      </a>
      <button class="nav-toggle" onclick="app.toggleNav()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav" id="main-nav">
        <button class="btn btn-secondary btn-sm" id="nav-dashboard" onclick="app.navigate('dashboard')">📊 Dashboard</button>
        <button class="btn btn-secondary btn-sm" id="nav-users" onclick="app.navigate('users')">👥 Players</button>
        <button class="btn btn-secondary btn-sm" id="nav-games" onclick="app.navigate('games')">🎲 Games</button>
        <button class="btn btn-secondary btn-sm" id="nav-matches" onclick="app.navigate('matches')">📈 Matches</button>
        <button class="btn btn-secondary btn-sm" id="nav-analytics" onclick="app.navigate('analytics')">🏆 Analytics</button>
        <button class="btn btn-secondary btn-sm" id="nav-wheel" onclick="app.navigate('wheel')">🎯 Random Picker</button>
        <button class="btn btn-secondary btn-sm" id="nav-settings" onclick="app.navigate('settings')">⚙️ Settings</button>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <div class="page">
      <div class="container">
        <p>Loading...</p>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🎲 Board Game Tracker - Track your games, compete with friends</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
</body>
</html>
